<mxGraphModel><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="tap 配置加载与 help 自声明解析" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="220" y="20" width="360" height="40" as="geometry"/></mxCell><mxCell id="3" value="CLI Entry&lt;br&gt;runCli(argv)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="320" y="80" width="160" height="50" as="geometry"/></mxCell><mxCell id="4" value="listAdapters()" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="95" y="170" width="140" height="50" as="geometry"/></mxCell><mxCell id="5" value="getAdapterDirectories()&lt;br&gt;1. TAP_ADAPTERS_DIR (可选)&lt;br&gt;2. 内置 adapters/&lt;br&gt;3. ~/.tap/adapters" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="35" y="255" width="255" height="100" as="geometry"/></mxCell><mxCell id="6" value="扫描各目录下&lt;br&gt;&amp;lt;site&amp;gt;/&amp;lt;command&amp;gt;.js&lt;br&gt;合并 sites / commands" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="45" y="395" width="235" height="80" as="geometry"/></mxCell><mxCell id="7" value="帮助请求?&lt;br&gt;help / --help / -h" style="rhombus;whiteSpace=wrap;html=1;fontSize=13;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="310" y="170" width="180" height="80" as="geometry"/></mxCell><mxCell id="8" value="globalHelp() / siteHelp()&lt;br&gt;直接使用 listAdapters() 的发现结果" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="300" y="320" width="205" height="80" as="geometry"/></mxCell><mxCell id="9" value="需要命令级 help?&lt;br&gt;例如 tap help linuxdo news&lt;br&gt;或 tap linuxdo news --help" style="rhombus;whiteSpace=wrap;html=1;fontSize=13;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="540" y="160" width="215" height="100" as="geometry"/></mxCell><mxCell id="10" value="loadAdapter(site, command)&lt;br&gt;按目录优先级解析具体文件" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="570" y="320" width="155" height="80" as="geometry"/></mxCell><mxCell id="11" value="import adapter module&lt;br&gt;导出 default 对象" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="570" y="435" width="155" height="70" as="geometry"/></mxCell><mxCell id="12" value="help 自声明来源&lt;br&gt;adapter.description&lt;br&gt;adapter.args&lt;br&gt;adapter.columns" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1"><mxGeometry x="530" y="530" width="225" height="105" as="geometry"/></mxCell><mxCell id="13" value="commandHelp()&lt;br&gt;拼出 Usage / Options / Output Columns" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="290" y="530" width="220" height="85" as="geometry"/></mxCell><mxCell id="14" value="执行命令路径" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="315" y="415" width="120" height="45" as="geometry"/></mxCell><mxCell id="15" value="parseArgs(rest)&lt;br&gt;命令行 --key value" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="290" y="470" width="160" height="75" as="geometry"/></mxCell><mxCell id="16" value="若缺省则回填&lt;br&gt;adapter.args[].default" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" paren